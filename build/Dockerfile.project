# Project-specific Dockerfile that builds on top of claudebox-core
FROM claudebox-core

# Switch to root for installations
USER root

{{PROFILE_INSTALLATIONS}}

{{LABELS}}

# Bake auth credentials into image (seeded to .claude/ by entrypoint)
RUN mkdir -p /opt/claudebox/auth
COPY auth-credentials.json /opt/claudebox/auth/credentials.json
RUN chown claude:claude /opt/claudebox/auth/credentials.json && \
    chmod 600 /opt/claudebox/auth/credentials.json

# Switch back to the claude user
USER claude
WORKDIR /workspace

# Copy entrypoint (in case it needs updating)
USER root
COPY --chown=claude docker-entrypoint.sh /usr/local/bin/docker-entrypoint
RUN sed -i 's|DOCKERUSER|claude|g' /usr/local/bin/docker-entrypoint && \
    chmod +x /usr/local/bin/docker-entrypoint

# Set the entrypoint
ENTRYPOINT ["/usr/local/bin/docker-entrypoint"]